{
  "name": "@yoyo-org/mockr",
  "version": "0.3.1",
  "description": "Endpoints are named data holders. Define a URL, attach data, and get a mock API server.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "vitest run && vitest run --config vitest.typecheck.config.ts",
    "test:watch": "vitest",
    "test:types": "vitest run --config vitest.typecheck.config.ts",
    "test:perf": "PERF=1 vitest run tests/perf-*.test.ts",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site",
    "publish:patch": "npm version patch && npm publish --access public && git push --follow-tags",
    "publish:minor": "npm version minor && npm publish --access public && git push --follow-tags",
    "publish:major": "npm version major && npm publish --access public && git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@yoyo-org/tui-kit": "^0.1.0",
    "path-to-regexp": "^8.2.0",
    "prettier": "^3.8.1",
    "ts-morph": "^27.0.2",
    "ws": "^8.20.0"
  }
}
