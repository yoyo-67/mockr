{
  "manifest_version": 3,
  "name": "mockr - Record & Map",
  "version": "0.2.0",
  "description": "Record network traffic and map responses to mockr endpoints",
  "permissions": [
    "devtools",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "devtools/devtools.html",
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
